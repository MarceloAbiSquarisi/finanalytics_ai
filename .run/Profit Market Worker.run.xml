<component name="ProjectRunConfigurationManager">
  <configuration default="false" name="Profit Market Worker" type="PythonConfigurationType" factoryName="Python">
    <module name="finanalytics-ai" />
    <envs>
      <env name="PYTHONPATH" value="$PROJECT_DIR$/src" />
    </envs>
    <option name="WORKING_DIRECTORY" value="$PROJECT_DIR$" />
    <option name="IS_MODULE_SDK" value="true" />
    <!-- IMPORTANTE: adicione .env.local via plugin EnvFile para sobrescrever DATABASE_URL -->
    <!-- Settings > Plugins > EnvFile > Enable > aba EnvFile > + > .env.local -->
    <!--
      O profit_market_worker.py usa WindowsSelectorEventLoopPolicy automaticamente.
      Nao e necessario configurar manualmente.

      Ordem de inicializacao (critica para a DLL):
        1. DLL conecta (antes de qualquer import de asyncpg/redis)
        2. wait_connected(timeout=90s)
        3. Inicializa DB/Redis
        4. Inicia EventConsumerWorker
    -->
    <option name="SCRIPT_NAME" value="-m finanalytics_ai.workers.profit_market_worker" />
    <option name="PARAMETERS" value="" />
    <option name="MODULE_MODE" value="true" />
    <method v="2" />
  </configuration>
</component>