# mypy.ini
# Arquivo auxiliar para o plugin do PyCharm (mypy-extensions) que lê .ini
# diretamente. As configurações espelham [tool.mypy] do pyproject.toml.
# NÃO editar um sem editar o outro — pyproject.toml é a fonte da verdade.

[mypy]
mypy_path = src
explicit_package_bases = True
python_version       = 3.12
strict               = True
warn_return_any      = True
warn_unused_configs  = True
warn_unused_ignores  = True
no_implicit_reexport = True
show_error_codes     = True
pretty               = True
plugins              = sqlalchemy.ext.mypy.plugin, pydantic.mypy

[mypy-asyncpg.*]
ignore_missing_imports = True

[mypy-prometheus_client.*]
ignore_missing_imports = True

[mypy-alembic.*]
ignore_missing_imports = True

[mypy-lightgbm.*]
ignore_missing_imports = True

[mypy-arch.*]
ignore_missing_imports = True

[mypy-pdfplumber.*]
ignore_missing_imports = True

[mypy-reportlab.*]
ignore_missing_imports = True

[mypy-opentelemetry.*]
ignore_missing_imports = True

[mypy-aiokafka.*]
ignore_missing_imports = True

[mypy-factory_boy.*]
ignore_missing_imports = True

[mypy-freezegun.*]
ignore_missing_imports = True

[mypy-tests.*]
disallow_untyped_defs = False

