FROM postgres:16-alpine

RUN apk add --no-cache tzdata

COPY docker-backup.sh /usr/local/bin/docker-backup.sh
RUN chmod +x /usr/local/bin/docker-backup.sh

# Loop shell: acorda a cada 30s, verifica se é hora do backup (05:00 UTC = 02:00 BRT)
# Mais simples e sem problemas de permissão do dcron em containers não-privilegiados
CMD ["/bin/sh", "-c", "\
  echo 'Backup service started. Scheduled: 05:00 UTC (02:00 BRT) daily.' && \
  while true; do \
    HOUR=$(date -u +%H); \
    MIN=$(date -u +%M); \
    if [ \"$HOUR\" = \"05\" ] && [ \"$MIN\" = \"00\" ]; then \
      /usr/local/bin/docker-backup.sh; \
      sleep 61; \
    fi; \
    sleep 30; \
  done \
"]
