# ──────────────────────────────────────────────────────────────────────────────
# finanalytics_ai — .env.example
# Copie para .env e preencha os valores reais.
# PyCharm: instale o plugin "EnvFile" e aponte para .env em Run Configurations.
# ──────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://finanalytics:secret@localhost:5432/finanalytics
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ── Segurança ──────────────────────────────────────────────────────────────────
APP_SECRET_KEY=dev-secret-key-local-alembic

# ── Fintz API ──────────────────────────────────────────────────────────────────
FINTZ_API_KEY=<sua-chave>
FINTZ_BASE_URL=https://api.fintz.com.br
FINTZ_REQUEST_TIMEOUT=30
FINTZ_MAX_RETRIES=3

# ── Event Processor ────────────────────────────────────────────────────────────
# Concorrência máxima de eventos processados em paralelo
EVENT_PROCESSOR_CONCURRENCY=10
# Máximo de tentativas por evento antes de mover para dead-letter
EVENT_MAX_RETRIES=5
# Delay base (segundos) para backoff exponencial
EVENT_RETRY_BASE_DELAY=1.0
# TTL (segundos) para lock de idempotência em cache
EVENT_IDEMPOTENCY_TTL=3600

# ── Observabilidade ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json          # json | text  (text é mais legível no terminal local)
METRICS_ENABLED=true
TRACING_ENABLED=false
TRACING_OTLP_ENDPOINT=http://localhost:4317

# ── Runtime ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | staging | production
DEBUG=true

# ── Pushover (Sprint Fix Alerts D, 21/abr/2026) ──────────────────────────────
# Push notifications system-wide:
#  - api: alertas de indicador (NotificationBus -> Pushover subscriber)
#  - grafana: 12 alert rules via provisioning/alerting/contact-points.yml
#  - qualquer modulo: from finanalytics_ai.infrastructure.notifications.pushover
#                     import notify_system; await notify_system(...)
#
# Setup (5 min):
#  1. Criar conta gratuita: https://pushover.net (USD 5 one-time por plataforma)
#  2. Copiar User Key do dashboard (perfil) -> PUSHOVER_USER_KEY
#  3. Criar app: https://pushover.net/apps/build (nome "FinAnalytics")
#  4. Copiar API Token/Key gerado -> PUSHOVER_APP_TOKEN
#  5. Tambem para Grafana: GRAFANA_PUSHOVER_USER_KEY/APP_TOKEN (mesmas keys)
#  6. docker compose up -d api grafana (recreate para env load)
#
# Vazio = canal Pushover desabilitado silenciosamente (nao quebra app).
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
PUSHOVER_ENABLED=
GRAFANA_PUSHOVER_USER_KEY=
GRAFANA_PUSHOVER_APP_TOKEN=

# ── Grafana Alertmanager API (para sub-aba Notificações em /admin) ──────────
# Permite criar/expirar silences direto da UI. Sem isso, o card Grafana fica
# desabilitado mas o resto da sub-aba funciona normalmente.
#
# OPCAO 1 (recomendada): Service Account Token
#  Grafana UI > Administration > Service Accounts > Add service account
#  > Add token. Role minima: 'Editor' (ou 'Admin' p/ silences globais).
#
# OPCAO 2: Basic auth fallback ("user:password")
GRAFANA_URL=http://grafana:3000
GRAFANA_API_TOKEN=
GRAFANA_BASIC_AUTH=
