# ──────────────────────────────────────────────────────────────────────────────
# FinAnalytics AI — .env.example
# Copie para .env e preencha os valores reais.
# PyCharm: instale o plugin "EnvFile" e aponte para .env em Run/Debug Configuration.
# ──────────────────────────────────────────────────────────────────────────────

# ── Ambiente ──────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_LOG_LEVEL=DEBUG          # DEBUG | INFO | WARNING | ERROR
APP_LOG_FORMAT=json          # json | console
APP_SECRET_KEY=change-me-in-production

# ── Banco de dados (PostgreSQL async) ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/finanalytics
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false           # true para logar queries (dev only)

# ── Broker / Fila de eventos ──────────────────────────────────────────────────
# Suporte: memory (dev/test) | redis | rabbitmq
EVENT_QUEUE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# ── APIs de Mercado ───────────────────────────────────────────────────────────
BRAPI_TOKEN=your-brapi-token-here
BRAPI_BASE_URL=https://brapi.dev/api

# ── Corretoras ────────────────────────────────────────────────────────────────
XP_API_KEY=
XP_API_SECRET=
XP_ACCOUNT_ID=

BTG_API_KEY=
BTG_API_SECRET=
BTG_ACCOUNT_ID=

# ── OpenFinance (futuro) ──────────────────────────────────────────────────────
OPEN_FINANCE_CLIENT_ID=
OPEN_FINANCE_CLIENT_SECRET=

# ── LLM (análise de notícias / recomendações) ────────────────────────────────
LLM_PROVIDER=openai           # openai | anthropic | local
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Observabilidade ───────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=finanalytics-ai
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER=parentbased_always_on
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# ── Resiliência ───────────────────────────────────────────────────────────────
# Máximo de retentativas para falhas transitórias em adapters externos
HTTP_RETRY_MAX_ATTEMPTS=3
HTTP_RETRY_WAIT_SECONDS=1.0
HTTP_TIMEOUT_SECONDS=30.0

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_BACKTESTING=true
FEATURE_NEURAL_NETWORKS=false
FEATURE_OPEN_FINANCE=false
FEATURE_REAL_TIME_DASHBOARD=true

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Defina EVENT_QUEUE_BACKEND=kafka para ativar consumo real do Kafka
# EVENT_QUEUE_BACKEND=kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_MARKET_EVENTS=market-events
KAFKA_TOPIC_PRICE_UPDATES=price-updates
KAFKA_CONSUMER_GROUP=finanalytics-ai
KAFKA_AUTO_OFFSET_RESET=latest

# ── TimescaleDB ───────────────────────────────────────────────────────────────
TIMESCALE_URL=postgresql://finanalytics:secret@localhost:5433/finanalytics
TIMESCALE_POOL_SIZE=5
