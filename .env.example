# ──────────────────────────────────────────────────────────────────────────────
# finanalytics_ai — .env.example
# Copie para .env e preencha os valores reais.
# PyCharm: instale o plugin "EnvFile" e aponte para .env em Run Configurations.
# ──────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://finanalytics:secret@localhost:5432/finanalytics
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ── Segurança ──────────────────────────────────────────────────────────────────
APP_SECRET_KEY=dev-secret-key-local-alembic

# ── Fintz API ──────────────────────────────────────────────────────────────────
FINTZ_API_KEY=<sua-chave>
FINTZ_BASE_URL=https://api.fintz.com.br
FINTZ_REQUEST_TIMEOUT=30
FINTZ_MAX_RETRIES=3

# ── Event Processor ────────────────────────────────────────────────────────────
# Concorrência máxima de eventos processados em paralelo
EVENT_PROCESSOR_CONCURRENCY=10
# Máximo de tentativas por evento antes de mover para dead-letter
EVENT_MAX_RETRIES=5
# Delay base (segundos) para backoff exponencial
EVENT_RETRY_BASE_DELAY=1.0
# TTL (segundos) para lock de idempotência em cache
EVENT_IDEMPOTENCY_TTL=3600

# ── Observabilidade ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json          # json | text  (text é mais legível no terminal local)
METRICS_ENABLED=true
TRACING_ENABLED=false
TRACING_OTLP_ENDPOINT=http://localhost:4317

# ── Runtime ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | staging | production
DEBUG=true
