{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "FinAnalytics AI — Observabilidade completa da plataforma",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "HTTP — Visão Geral",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 100},
            {"color": "red", "value": 500}
          ]},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "Requests/s",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(rate(finanalytics_http_requests_total[1m]))",
        "legendFormat": "req/s"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.5},
            {"color": "red", "value": 2.0}
          ]},
          "unit": "s"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "Latência P99",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "histogram_quantile(0.99, sum(rate(finanalytics_http_request_duration_seconds_bucket[5m])) by (le))",
        "legendFormat": "P99"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "red", "value": 1}
          ]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "Erros 5xx (1m)",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(increase(finanalytics_http_requests_total{status_code=~\"5..\"}[1m])) or vector(0)",
        "legendFormat": "5xx"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "title": "In-Flight",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(finanalytics_http_requests_in_flight) or vector(0)",
        "legendFormat": "in-flight"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}},
        "overrides": [{"matcher": {"id": "byRegexp", "options": "5.."}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "id": 5,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "HTTP Requests por Rota (rate 1m)",
      "type": "timeseries",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(rate(finanalytics_http_requests_total[1m])) by (path, method)",
        "legendFormat": "{{method}} {{path}}"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "id": 6,
      "title": "Latência HTTP — P50 / P95 / P99",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.50, sum(rate(finanalytics_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "P50 {{path}}"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, sum(rate(finanalytics_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "P95 {{path}}"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.99, sum(rate(finanalytics_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "P99 {{path}}"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13},
      "id": 101,
      "title": "Módulos de Negócio",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 14},
      "id": 10,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "title": "Anomaly Scans (total)",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(finanalytics_anomaly_scans_total) or vector(0)",
        "legendFormat": "scans"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 20}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 14},
      "id": 11,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "Anomalias Detectadas (total)",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(finanalytics_anomaly_detections_total) or vector(0)",
        "legendFormat": "detections"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 14},
      "id": 12,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "title": "Screener Runs (total)",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(finanalytics_screener_runs_total) or vector(0)"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 14},
      "id": 13,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "title": "Backtest Runs (total)",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(finanalytics_backtest_runs_total) or vector(0)"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 14},
      "id": 14,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "Alertas Ativos",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "finanalytics_alerts_active or vector(0)"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
      "id": 20,
      "title": "Anomalias por Algoritmo e Severidade (rate 5m)",
      "type": "timeseries",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(rate(finanalytics_anomaly_detections_total[5m])) by (algorithm, severity)",
        "legendFormat": "{{algorithm}} / {{severity}}"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "palette-classic"}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "id": 21,
      "title": "Screener — Taxa de Aprovação por Execução",
      "type": "timeseries",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "histogram_quantile(0.5, rate(finanalytics_screener_pass_rate_bucket[10m]))",
        "legendFormat": "Pass rate median"
      }]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 26},
      "id": 102,
      "title": "BRAPI — Dados de Mercado",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 27},
      "id": 30,
      "title": "BRAPI Requests por Status (rate 1m)",
      "type": "timeseries",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(rate(finanalytics_brapi_requests_total[1m])) by (status)",
        "legendFormat": "{{status}}"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 27},
      "id": 31,
      "title": "BRAPI Latência P50 / P95 (5m)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.50, sum(rate(finanalytics_brapi_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, sum(rate(finanalytics_brapi_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 35},
      "id": 103,
      "title": "Producer / Kafka",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
      "id": 40,
      "title": "Price Producer Polls por Status (rate 1m)",
      "type": "timeseries",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(rate(finanalytics_price_producer_polls_total[1m])) by (status)",
        "legendFormat": "{{status}}"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
      "id": 41,
      "title": "Kafka Messages Consumed (rate 1m)",
      "type": "timeseries",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(rate(finanalytics_kafka_messages_consumed_total[1m])) by (event_type)",
        "legendFormat": "{{event_type}}"
      }]
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["finanalytics", "observability"],
  "templating": {
    "list": [{
      "current": {},
      "hide": 0,
      "includeAll": false,
      "name": "DS_PROMETHEUS",
      "options": [],
      "query": "prometheus",
      "refresh": 1,
      "type": "datasource"
    }]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "FinAnalytics AI — Observabilidade",
  "uid": "finanalytics-obs-v1",
  "version": 1
}
