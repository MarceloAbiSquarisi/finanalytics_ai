{
  "panels": [
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "timescale_main"
      },
      "description": "Via gap_map_1m. pct_cob_intraday = minutos_com_tick / 420. tem_profit_ok usa threshold tiered por mediana_vol_brl.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "pct_cob_intraday"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 40
                    },
                    {
                      "color": "green",
                      "value": 70
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "tem_profit_ok"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "false": {
                        "color": "red",
                        "text": "âœ—"
                      },
                      "true": {
                        "color": "green",
                        "text": "âœ“"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "tem_fintz"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "false": {
                        "color": "red",
                        "text": "âœ—"
                      },
                      "true": {
                        "color": "green",
                        "text": "âœ“"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "mediana_vol_brl"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyBRL"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT dia, ticker, classe, minutos_com_tick, pct_cob_intraday, threshold_minutos, tem_profit_ok, tem_fintz, mediana_vol_brl FROM gap_map_1m WHERE dia >= (CURRENT_DATE - INTERVAL '30 days') AND (mediana_vol_brl > 10000000 OR classe = 'future') ORDER BY dia DESC, coalesce(mediana_vol_brl, 999999999999) DESC LIMIT 1000;",
          "refId": "A"
        }
      ],
      "title": "Painel 1 â€” Cobertura intraday 30d (liquidez > 10M ou futuro)",
      "type": "table"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "timescale_main"
      },
      "description": "Calcula horas desde o Ãºltimo dia materializado em profit_daily_cov. Alerta se atraso > 24h em dia Ãºtil. Nota: profit_daily_cov sÃ³ cobre janela populada (hoje 2026-03-20â†’2026-04-17).",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "atraso_horas"
            },
            "properties": [
              {
                "id": "unit",
                "value": "h"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 24
                    },
                    {
                      "color": "red",
                      "value": 72
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "mediana_vol_brl"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyBRL"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 2,
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT p.ticker, max(p.dia) AS ultimo_dia, EXTRACT(EPOCH FROM (now() - (max(p.dia)::timestamp + interval '17 hours')))/3600 AS atraso_horas, w.mediana_vol_brl FROM profit_daily_cov p LEFT JOIN watchlist_tickers w ON w.ticker = p.ticker GROUP BY p.ticker, w.mediana_vol_brl ORDER BY atraso_horas DESC LIMIT 30;",
          "refId": "A"
        }
      ],
      "title": "Painel 2 â€” LatÃªncia por ticker (Ãºltimo dia coberto em profit_daily_cov)",
      "type": "table"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "timescale_main"
      },
      "description": "ohlc_1m do dia corrente, janela 10:00-17:00. Ideal: curva constante em ~130. Queda = falha de coleta.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "green",
                "value": 100
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 3,
      "targets": [
        {
          "format": "time_series",
          "rawSql": "WITH m AS (SELECT generate_series(date_trunc('day', now()) + interval '10 hours', date_trunc('day', now()) + interval '17 hours', interval '1 minute') AS minuto) SELECT m.minuto AS time, count(o.ticker) AS tickers_com_candle FROM m LEFT JOIN ohlc_1m o ON o.time = m.minuto GROUP BY m.minuto ORDER BY m.minuto;",
          "refId": "A"
        }
      ],
      "title": "Painel 3 â€” Tickers com candle por minuto (hoje)",
      "type": "timeseries"
    },
